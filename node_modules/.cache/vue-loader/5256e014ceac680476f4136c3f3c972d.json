{"remainingRequest":"/home/runner/work/U1_Biologia_desarrollo_humano/U1_Biologia_desarrollo_humano/node_modules/vue-loader/lib/index.js??vue-loader-options!/home/runner/work/U1_Biologia_desarrollo_humano/U1_Biologia_desarrollo_humano/src/views/ActividadDidactica.vue?vue&type=script&lang=js&","dependencies":[{"path":"/home/runner/work/U1_Biologia_desarrollo_humano/U1_Biologia_desarrollo_humano/src/views/ActividadDidactica.vue","mtime":1735408565276},{"path":"/home/runner/work/U1_Biologia_desarrollo_humano/U1_Biologia_desarrollo_humano/node_modules/babel-loader/lib/index.js","mtime":456789000000},{"path":"/home/runner/work/U1_Biologia_desarrollo_humano/U1_Biologia_desarrollo_humano/node_modules/cache-loader/dist/cjs.js","mtime":499162500000},{"path":"/home/runner/work/U1_Biologia_desarrollo_humano/U1_Biologia_desarrollo_humano/node_modules/vue-loader/lib/index.js","mtime":499162500000}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["ActividadDidactica.vue"],"names":[],"mappings":";;;;;;;;;;;AAWA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA","file":"ActividadDidactica.vue","sourceRoot":"src/views","sourcesContent":["<template lang=\"pug\">\n  .curso-main-container.pb-3\n    BannerInterno(icono=\"far fa-question-circle\" titulo=\"Actividad didáctica\")\n    .container.tarjeta.tarjeta--blanca.p-4.p-md-5\n  \n      #Actividad                \n        <Actividad :cuestionario=\"cuestionario\"/>\n  \n  </template>\n\n<script>\nimport Actividad from '@/components/actividad/Actividad.vue'\nexport default {\n  name: 'ActividadDidactica',\n  components: {\n    Actividad,\n  },\n  data: () => ({\n    cuestionario: {\n      tema: 'Genética y Herencia',\n      titulo: 'Cuestionario de Evaluación',\n      introduccion:\n        '<b>Objetivo:</b> Evaluar los conocimientos sobre conceptos básicos de genética, herencia y expresión génica.',\n      barajarPreguntas: true,\n      preguntas: [\n        {\n          id: 1,\n          texto: '¿Qué es un fenotipo?',\n          barajarRespuestas: true,\n          opciones: [\n            {\n              id: 'a',\n              texto: 'La composición genética de un individuo',\n              esCorrecta: false,\n            },\n            { id: 'b', texto: 'Las mutaciones en el ADN', esCorrecta: false },\n            {\n              id: 'c',\n              texto: 'La combinación de alelos en un gen',\n              esCorrecta: false,\n            },\n            {\n              id: 'd',\n              texto:\n                'La descripción de las características físicas de un organismo',\n              esCorrecta: true,\n            },\n          ],\n          mensaje_correcto: '¡Muy bien! Ha acertado la respuesta.',\n          mensaje_incorrecto: 'Lo sentimos, su respuesta no es la correcta.',\n        },\n        {\n          id: 2,\n          texto:\n            'La barba, el color del cabello, la estatura y algunos rasgos comportamentales de los seres vivos, corresponden a la expresión de los genes y son su expresión en lo que se refiere al:',\n          barajarRespuestas: true,\n          opciones: [\n            { id: 'a', texto: 'Genotipo', esCorrecta: false },\n            { id: 'b', texto: 'Fenotipo', esCorrecta: true },\n            { id: 'c', texto: 'ADN', esCorrecta: false },\n            { id: 'd', texto: 'Transcripción del ADN', esCorrecta: false },\n          ],\n          mensaje_correcto: '¡Muy bien! Ha acertado la respuesta.',\n          mensaje_incorrecto: 'Lo sentimos, su respuesta no es la correcta.',\n        },\n        {\n          id: 3,\n          texto: 'Según Gregor Mendel, ¿qué son los alelos dominantes?',\n          barajarRespuestas: true,\n          opciones: [\n            {\n              id: 'a',\n              texto: 'No se transmiten a la siguiente generación',\n              esCorrecta: false,\n            },\n            {\n              id: 'b',\n              texto: 'Son la versión más fuerte de un par de alelos',\n              esCorrecta: true,\n            },\n            {\n              id: 'c',\n              texto: 'Siempre son más raros que los alelos recesivos',\n              esCorrecta: false,\n            },\n            {\n              id: 'd',\n              texto: 'Se encuentran solo en individuos masculinos',\n              esCorrecta: false,\n            },\n          ],\n          mensaje_correcto: '¡Muy bien! Ha acertado la respuesta.',\n          mensaje_incorrecto: 'Lo sentimos, su respuesta no es la correcta.',\n        },\n        {\n          id: 4,\n          texto: '¿Qué es una mutación?',\n          barajarRespuestas: true,\n          opciones: [\n            {\n              id: 'a',\n              texto: 'Un proceso de autoinmunidad',\n              esCorrecta: false,\n            },\n            { id: 'b', texto: 'Un tipo de célula sexual', esCorrecta: false },\n            {\n              id: 'c',\n              texto: 'Un cambio en una secuencia del ADN',\n              esCorrecta: true,\n            },\n            { id: 'd', texto: 'Una suma de ADN', esCorrecta: false },\n          ],\n          mensaje_correcto: '¡Muy bien! Ha acertado la respuesta.',\n          mensaje_incorrecto: 'Lo sentimos, su respuesta no es la correcta.',\n        },\n        {\n          id: 5,\n          texto:\n            'En el clásico ejemplo de herencia mendeliana, donde se cruzan dos plantas de Arveja, donde el fruto es Amarillo (AA), ¿Qué significa que las letras AA estén en mayúsculas?',\n          barajarRespuestas: true,\n          opciones: [\n            {\n              id: 'a',\n              texto:\n                'AA significa que tiene dos alelos dominantes para el color Amarillo y es homocigoto',\n              esCorrecta: true,\n            },\n            {\n              id: 'b',\n              texto:\n                'AA significa que tiene dos alelos recesivos para el color Amarillo y es homocigoto',\n              esCorrecta: false,\n            },\n            {\n              id: 'c',\n              texto: 'AA significa que es heterocigoto para el color Amarillo',\n              esCorrecta: false,\n            },\n            {\n              id: 'd',\n              texto:\n                'AA no tiene ninguna relación con temas de la genética, es solo un modo de expresión',\n              esCorrecta: false,\n            },\n          ],\n          mensaje_correcto: '¡Muy bien! Ha acertado la respuesta.',\n          mensaje_incorrecto: 'Lo sentimos, su respuesta no es la correcta.',\n        },\n      ],\n      mensaje_final_aprobado: '¡Excelente! Ha superado la actividad.',\n      mensaje_final_reprobado:\n        'Le recomendamos volver a revisar el componente formativo e intentar nuevamente la actividad didáctica.',\n    },\n  }),\n}\n</script>\n"]}]}